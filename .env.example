# VisionFlow AI — Environment Variables
# Copy this to .env.local and fill in your values

# OpenAI (required)
VITE_OPENAI_API_KEY=sk-...

# Pinecone (required)
VITE_PINECONE_API_KEY=...
VITE_PINECONE_INDEX=n8n
VITE_PINECONE_NAMESPACE=1

# WhatsApp / Meta (required)
VITE_WA_PHONE_NUMBER_ID=...
VITE_WA_ACCESS_TOKEN=...
VITE_WA_VERIFY_TOKEN=optician_secret_2025

# n8n webhook (required)
VITE_N8N_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/whatsapp

# App
VITE_APP_NAME=VisionFlow AI
VITE_APP_URL=https://app.visionflow.ai
